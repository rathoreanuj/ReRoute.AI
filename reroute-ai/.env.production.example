# Copy to .env.production and fill in before: docker compose -f docker-compose.prod.yml --env-file .env.production up -d --build

# --- Database (docker-compose.prod.yml) ---
POSTGRES_USER=reroute
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=reroute

# --- Public URLs (must match how users reach your app) ---
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# Build-time / runtime (frontend container uses build arg from this at compose build)
NEXT_PUBLIC_REROUTE_AGENT_ASYNC=0

# --- Auth (required in production) ---
JWT_SECRET_KEY=generate-a-long-random-string
COOKIE_SECURE=false
# Set COOKIE_SECURE=true when using HTTPS

# Google OAuth (optional)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# --- Integrations ---
DUFFEL_API_KEY=
OPENAI_API_KEY=
RESEND_API_KEY=
AVIATION_STACK_API_KEY=
OPENROUTESERVICE_API_KEY=

# Email via Celery (set true when worker + beat are running)
EMAIL_VIA_CELERY=true

# --- Ports exposed on the host (docker-compose.prod.yml) ---
API_PORT=8000
FRONTEND_PORT=3000
